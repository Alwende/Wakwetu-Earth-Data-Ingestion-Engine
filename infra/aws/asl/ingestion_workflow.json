{
  "StartAt": "TriggerIngestor",
  "States": {
    "TriggerIngestor": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:123456789012:function:EarthData-Ingestor",
      "Next": "ProcessAssets"
    },
    "ProcessAssets": {
      "Type": "Map",
      "ItemsPath": "$.assets",
      "MaxConcurrency": 10,
      "Iterator": {
        "StartAt": "NormalizeToCOG",
        "States": {
          "NormalizeToCOG": {
            "Type": "Task",
            "Resource": "arn:aws:lambda:us-east-1:123456789012:function:EarthData-Transformer",
            "End": true
          }
        }
      },
      "End": true
    }
  }
}
